{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git diff": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "ls*": "allow",
      "npx openspec *": "allow",
      "openspec *": "allow"
    },
    "edit": {
      "*": "ask",
      "openspec/*": "allow"
    }
  }
}
